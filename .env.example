# === LLM 設定 ===
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b

# Gemini API（選填，啟用後 Stage 3 評語會走 Gemini）
# GEMINI_API_KEY=your-gemini-api-key-here
# GEMINI_MODEL=gemini-2.0-flash

# === 資料庫 ===
# SQLite（預設）
DATABASE_URL=sqlite:///./eq_grader.db
# PostgreSQL（取消註解並填入你的連線資訊）
# DATABASE_URL=postgresql://user:password@192.168.x.x:5432/eq_grader

# === Google OAuth（老師登入用）===
# GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-client-secret
# super user（可管理帳號審核）
SUPER_USER_EMAIL=jenghan.hsieh@gmail.com
# 部署的 base URL（用於 OAuth callback）
APP_BASE_URL=http://localhost:8000

# Session 密鑰（請改成隨機字串）
SESSION_SECRET=change-me-to-a-random-string
